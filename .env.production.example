# Production Environment Configuration
# Copy this file to .env.production and fill in the values

# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=protecht_bim
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_DB=0

# JWT Configuration (use strong random strings)
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Session Configuration (use strong random strings)
SESSION_SECRET=CHANGE_ME_STRONG_RANDOM_STRING_MIN_32_CHARS
SESSION_TTL=86400
COOKIE_DOMAIN=yourdomain.com

# MinIO/S3 Configuration
STORAGE_PORT=9000
STORAGE_CONSOLE_PORT=9001
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=CHANGE_ME_STRONG_ACCESS_KEY
STORAGE_SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY
STORAGE_BUCKET=protecht-bim
STORAGE_USE_SSL=true

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=CHANGE_ME_USERNAME
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Application Configuration
NODE_ENV=production
API_PORT=3000
WEB_PORT=3001
BIM_PROCESSOR_PORT=3002

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# File Upload Configuration
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=.ifc,.rvt,.nwd,.pdf,.png,.jpg,.jpeg

# Logging
LOG_LEVEL=info

# Security Headers
HELMET_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (optional)
SENTRY_DSN=
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Backup Configuration (optional)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
