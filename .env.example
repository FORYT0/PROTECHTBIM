# ── PROTECHT BIM — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in values for local development.
# For production, set these in your hosting dashboard (Render / Railway / Fly.io).

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────
# Option 1: Full connection URL (recommended — works with Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/protecht_bim

# Option 2: Individual params (used if DATABASE_URL is not set)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=protecht_bim

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_in_production_use_32_random_bytes

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ── AI (Groq) ───────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# ── Redis (optional) ────────────────────────────────────────────────────────
# If not set, Redis is skipped. Real-time features still work via polling.
# REDIS_URL=redis://localhost:6379
