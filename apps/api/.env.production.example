# ============================================================
# PROTECHT BIM — Railway Production Environment Variables
# Copy each into Railway → Service → Variables
# [RAILWAY] = auto-provided by Railway plugin (copy from Connect tab)
# [GENERATE] = run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# App
NODE_ENV=production
API_PORT=3000
LOG_LEVEL=info

# Database [RAILWAY - copy from PostgreSQL plugin → Connect tab]
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=railway
DATABASE_USER=postgres
DATABASE_PASSWORD=

# Redis [RAILWAY - copy from Redis plugin → Connect tab]
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT [GENERATE - run the command above]
JWT_SECRET=
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Session [GENERATE - use a DIFFERENT value from JWT_SECRET]
SESSION_SECRET=
SESSION_TTL=86400
COOKIE_DOMAIN=

# CORS [your Vercel frontend URL]
CORS_ORIGIN=https://your-app.vercel.app

# Storage (Phase 4 - leave blank for now)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=protecht-bim
STORAGE_USE_SSL=true

# File Uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=.ifc,.rvt,.nwd,.pdf,.png,.jpg,.jpeg,.dwg
