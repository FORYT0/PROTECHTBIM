# Production environment variables for Vercel deployment
# VITE_ prefix vars are baked into the JS bundle at build time
#
# HOW TO FIND YOUR RAILWAY URL:
#   1. Go to https://railway.app
#   2. Open your protecht-bim project
#   3. Click on the API service -> Settings -> Domains
#   4. Copy the URL and replace below
#
# The URL format is typically: https://XXXX.up.railway.app
# Example: https://protecht-bim-api-production.up.railway.app

VITE_API_URL=https://protecht-bim-api-production.up.railway.app/api/v1
VITE_WS_URL=https://protecht-bim-api-production.up.railway.app
