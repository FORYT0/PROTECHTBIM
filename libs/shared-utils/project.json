{
  "name": "shared-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared-utils/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared-utils",
        "main": "libs/shared-utils/src/index.ts",
        "tsConfig": "libs/shared-utils/tsconfig.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/shared-utils/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared-utils"],
      "options": {
        "jestConfig": "libs/shared-utils/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["type:library", "scope:shared"]
}
